{
  "version": 1,
  "id": "codex",
  "role": "executor",
  "transport": "cli",
  "command": [
    "codex",
    "exec",
    "--skip-git-repo-check",
    "--sandbox",
    "workspace-write",
    "--add-dir",
    "{work}",
    "--output-last-message",
    "{output}",
    "{prompt}"
  ],
  "validate": ["codex", "--version"],
  "capabilities": { "roles": ["executor"], "features": ["code", "refactor", "test"], "auth": true },
  "description": "Codex CLI executor adapter."
}
