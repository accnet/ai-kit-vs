{
  "version": 1,
  "id": "codex",
  "role": "planner",
  "transport": "cli",
  "prompt_transport": "stdin",
  "command": [
    "codex",
    "exec",
    "--skip-git-repo-check",
    "--sandbox",
    "workspace-write",
    "--add-dir",
    "{work}",
    "-c",
    "model_reasoning_effort=low",
    "--output-last-message",
    "{output}",
    "-"
  ],
  "description": "Codex CLI planner adapter."
}
